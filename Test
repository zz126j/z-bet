<script>
// ========== STATE ==========
const STATE = {
  balance: 1000,
  depositCount: 0,
  totalDeposited: 0,
  currentGame: null,
  lastActivity: 0,
};

function loadState() {
  try {
    const s = JSON.parse(localStorage.getItem('zbet_state') || '{}');
    if (s.balance !== undefined) STATE.balance = s.balance;
    if (s.depositCount !== undefined) STATE.depositCount = s.depositCount;
    if (s.totalDeposited !== undefined) STATE.totalDeposited = s.totalDeposited;
  } catch(e) {}
}
function saveState() {
  localStorage.setItem('zbet_state', JSON.stringify({
    balance: STATE.balance,
    depositCount: STATE.depositCount,
    totalDeposited: STATE.totalDeposited,
  }));
}

// ========== BALANCE ==========
let balanceAnimFrame = null;
function updateBalanceDisplay(newBal, animate = true) {
  const el = document.getElementById('balanceNum');
  if (!animate) { el.textContent = fmt(newBal); return; }
  const start = parseFloat(el.textContent.replace(/,/g, '')) || 0;
  const diff = newBal - start;
  const dur = 600;
  const t0 = performance.now();
  if (balanceAnimFrame) cancelAnimationFrame(balanceAnimFrame);
  function tick(t) {
    const p = Math.min((t - t0) / dur, 1);
    const ease = 1 - Math.pow(1 - p, 3);
    el.textContent = fmt(start + diff * ease);
    if (p < 1) balanceAnimFrame = requestAnimationFrame(tick);
  }
  balanceAnimFrame = requestAnimationFrame(tick);
}
function fmt(n) {
  return Math.max(0, n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}
function updateNav() {
  document.getElementById('navDepositCount').textContent = STATE.depositCount;
  document.getElementById('navTotalDeposited').textContent = '$' + fmt(STATE.totalDeposited);
  updateBalanceDisplay(STATE.balance);
}

function winBet(amount, gameEl) {
  STATE.balance += amount;
  saveState();
  updateNav();
  floatChip('+$' + fmt(amount), 'win', gameEl);
  showToast('Won $' + fmt(amount), 'win');
}
function loseBet(amount, gameEl) {
  STATE.balance -= amount;
  if (STATE.balance < 0) STATE.balance = 0;
  saveState();
  updateNav();
  floatChip('-$' + fmt(amount), 'lose', gameEl);
  showToast('Lost $' + fmt(amount), 'lose');
}

function floatChip(text, type, el) {
  const chip = document.createElement('div');
  chip.className = 'float-chip ' + type;
  chip.textContent = text;
  if (el) {
    const r = el.getBoundingClientRect();
    chip.style.left = (r.left + r.width/2 - 30) + 'px';
    chip.style.top = (r.top + r.height/2) + 'px';
  } else {
    chip.style.left = '50%';
    chip.style.top = '50%';
  }
  document.body.appendChild(chip);
  setTimeout(() => chip.remove(), 1100);
}

// ========== TOAST ==========
function showToast(msg, type = 'info', dur = 2200) {
  const c = document.getElementById('toastContainer');
  const t = document.createElement('div');
  t.className = 'toast ' + type;
  t.textContent = msg;
  c.appendChild(t);
  setTimeout(() => { t.style.opacity = '0'; t.style.transition = 'opacity 0.4s'; setTimeout(() => t.remove(), 400); }, dur);
}

// ========== DEPOSIT ==========
function openDeposit() {
  document.getElementById('depositModal').classList.add('open');
  document.getElementById('depositInput').value = '';
  document.getElementById('depositInput').focus();
}
function closeDeposit() {
  document.getElementById('depositModal').classList.remove('open');
}
function setDepositQuick(v) { document.getElementById('depositInput').value = v; }
function confirmDeposit() {
  const v = parseFloat(document.getElementById('depositInput').value);
  if (!v || v <= 0) { showToast('Enter a valid amount', 'info'); return; }
  STATE.balance += v;
  STATE.depositCount++;
  STATE.totalDeposited += v;
  saveState();
  closeDeposit();
  updateNav();
  showMockery();
  showToast('Deposited $' + fmt(v), 'info');
}
function showMockery() {
  const ov = document.getElementById('mockeryOverlay');
  ov.classList.add('show');
  setTimeout(() => {
    ov.style.transition = 'opacity 0.5s';
    ov.style.opacity = '0';
    setTimeout(() => {
      ov.classList.remove('show');
      ov.style.opacity = '';
      ov.style.transition = '';
    }, 500);
  }, 1000);
}

// ========== BG CANVAS ==========
(function() {
  const canvas = document.getElementById('bgCanvas');
  const ctx = canvas.getContext('2d');
  let W, H, particles = [], time = 0;
  function resize() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);
  for (let i = 0; i < 60; i++) {
    particles.push({
      x: Math.random() * 2000,
      y: Math.random() * 2000,
      r: Math.random() * 1.5 + 0.3,
      vx: (Math.random() - 0.5) * 0.15,
      vy: (Math.random() - 0.5) * 0.15,
      o: Math.random() * 0.4 + 0.05,
    });
  }
  function draw() {
    ctx.clearRect(0, 0, W, H);
    // subtle radial glow
    const grd = ctx.createRadialGradient(W/2, H*0.4, 0, W/2, H*0.4, W*0.6);
    grd.addColorStop(0, 'rgba(37,99,255,0.04)');
    grd.addColorStop(1, 'transparent');
    ctx.fillStyle = grd;
    ctx.fillRect(0, 0, W, H);
    // particles
    for (const p of particles) {
      p.x += p.vx; p.y += p.vy;
      if (p.x < -5) p.x = W + 5; if (p.x > W + 5) p.x = -5;
      if (p.y < -5) p.y = H + 5; if (p.y > H + 5) p.y = -5;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(100,160,255,${p.o})`;
      ctx.fill();
    }
    time++;
    requestAnimationFrame(draw);
  }
  draw();
})();

// ========== GAME DEFINITIONS ==========
const GAMES = [
  { id: 'blackjack', name: 'Blackjack', tag: 'Cards', color: '#1a3a8f', icon: 'bj' },
  { id: 'roulette', name: 'Roulette', tag: 'Table', color: '#1a4a2f', icon: 'rl' },
  { id: 'aviator', name: 'Aviator', tag: 'Crash', color: '#2a1a5f', icon: 'av' },
  { id: 'plinko', name: 'Plinko', tag: 'Physics', color: '#2a1f00', icon: 'pl' },
