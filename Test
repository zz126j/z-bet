// ========== GAME CARDS ==========
function buildGameCards() {
  const g1 = document.getElementById('gamesGrid');
  const g2 = document.getElementById('gamesGrid2');
  const featured = GAMES.slice(0, 12);
  const rest = GAMES.slice(12);
  featured.forEach(g => g1.appendChild(makeCard(g)));
  rest.forEach(g => g2.appendChild(makeCard(g)));
}

function makeCard(g) {
  const card = document.createElement('div');
  card.className = 'game-card';
  const svgStr = GAME_SVGS[g.icon] || '';
  card.innerHTML = `
    <div class="game-thumb" style="background:linear-gradient(135deg,${g.color}66,${g.color}22);">
      ${svgStr}
      <div class="game-thumb-overlay"></div>
      <div class="game-play-btn">Play Now</div>
    </div>
    <div class="game-info">
      <div class="game-name">${g.name}</div>
      <div class="game-tag">${g.tag}</div>
    </div>
  `;
  card.onclick = () => openGame(g.id);
  return card;
}

// ========== NAVIGATION ==========
function showHome() {
  if (STATE.currentGame && GAME_INSTANCES[STATE.currentGame] && GAME_INSTANCES[STATE.currentGame].destroy) {
    GAME_INSTANCES[STATE.currentGame].destroy();
  }
  STATE.currentGame = null;
  document.getElementById('homeScreen').classList.add('active');
  document.getElementById('gameScreen').classList.remove('active');
}

function openGame(id) {
  if (STATE.currentGame && GAME_INSTANCES[STATE.currentGame] && GAME_INSTANCES[STATE.currentGame].destroy) {
    GAME_INSTANCES[STATE.currentGame].destroy();
  }
  STATE.currentGame = id;
  const g = GAMES.find(x => x.id === id);
  document.getElementById('gameHeaderName').textContent = g.name;
  document.getElementById('gameHeaderTag').textContent = g.tag + ' Game';
  document.getElementById('homeScreen').classList.remove('active');
  document.getElementById('gameScreen').classList.add('active');
  document.getElementById('gameMain').innerHTML = '';
  document.getElementById('gameSidebar').innerHTML = '';
  const inst = GAME_RUNNERS[id];
  if (inst) {
    GAME_INSTANCES[id] = inst();
  }
}

