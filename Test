  render(false);
  return {destroy:()=>{}};
};

// ===== COLOR CRASH =====
GAME_RUNNERS.colors = function() {
  const main=document.getElementById('gameMain');
  const OPTS=[{id:'red',label:'Red',color:'var(--red)',prob:0.46},{id:'blue',label:'Blue',color:'var(--accent2)',prob:0.46},{id:'green',label:'Green',color:'var(--green)',prob:0.08}];
  const PAYS={red:2,blue:2,green:14};
  let spinning=false,chosen=null;
  function render(result=null){
    main.innerHTML=`<div style="padding:24px;display:flex;flex-direction:column;align-items:center;gap:20px;width:100%;">
      <div style="font-size:14px;color:var(--text2);">Pick a color to bet on</div>
      <div class="color-options" style="width:min(360px,90%);">
        ${OPTS.map(o=>`<div class="color-opt ${o.id}-opt${chosen===o.id?' selected':''}" style="border-width:${chosen===o.id?3:1}px" onclick="window._colorChose('${o.id}')">
          <div style="font-size:20px;font-weight:900">${o.label}</div>
          <div style="font-size:12px;margin-top:4px;opacity:0.7">${PAYS[o.id]}×</div>
        </div>`).join('')}
      </div>
      ${result?`<div style="width:100px;height:100px;border-radius:50%;background:${OPTS.find(o=>o.id===result)?.color};display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:900;color:#fff;box-shadow:0 0 24px ${OPTS.find(o=>o.id===result)?.color}">${result.toUpperCase()}</div>`:'<div style="width:100px;height:100px;border-radius:50%;background:var(--bg3);border:2px dashed var(--border);display:flex;align-items:center;justify-content:center;color:var(--text3);font-size:13px">?</div>'}
    </div>`;
  }
  window._colorChose=(id)=>{chosen=id;render();};
  render();
  makeBetPanel('gameSidebar',{label:'Place Bet',onPlay:'window._colorBet()'});
  window._colorBet=()=>{
    const bet=getBet();if(!bet||spinning||!chosen){if(!chosen)showToast('Choose a color first','info');return;}
    spinning=true;startCooldown(1500);
    setTimeout(()=>{
      const r=rng();
      let result='red',acc=0;
      for(let o of OPTS){acc+=o.prob;if(r<=acc){result=o.id;break;}}
      render(result);
      if(result===chosen){
        const p=bet*PAYS[chosen]*0.97;
        winBet(p-bet,main);setResult(chosen+' wins! +$'+fmt(p-bet),'win');addHistory('+$'+fmt(p-bet),'win');
      } else {
        loseBet(bet,main);setResult(result+' wins. -$'+fmt(bet),'lose');addHistory('-$'+fmt(bet),'lose');
      }
      spinning=false;
    },1200);
  };
  return {destroy:()=>{spinning=false;}};
};

// ===== REACTION TEST =====
GAME_RUNNERS.reaction = function() {
  const main=document.getElementById('gameMain');
  let phase='idle',timer=null,startTime=0,betAmount=0;
  const TIERS=[{ms:200,mult:3},{ms:300,mult:2},{ms:450,mult:1.5},{ms:600,mult:1.2}];
  function render(state,extra=''){
    const colors={idle:'rgba(10,20,50,0.5)',waiting:'rgba(10,20,50,0.5)',go:'rgba(0,100,50,0.4)',result:'rgba(10,20,50,0.5)'};
    main.innerHTML=`<div class="reaction-area" id="ra" style="background:${colors[state]};border:2px solid ${state==='go'?'var(--green)':'var(--border)'};" onclick="window._reactionTap()">
      <div style="text-align:center;padding:30px;">
        ${state==='idle'?`<div style="font-size:28px;font-weight:900;color:var(--text2)">Tap to Start!</div><div style="font-size:13px;color:var(--text3);margin-top:8px">Faster = bigger win</div>`:''}
        ${state==='waiting'?`<div style="font-size:28px;font-weight:900;color:var(--text3)">Wait for green...</div>`:''}
        ${state==='go'?`<div style="font-size:48px;font-weight:900;color:var(--green);text-shadow:0 0 20px rgba(0,200,80,0.6)">TAP!</div>`:''}
        ${state==='early'?`<div style="font-size:28px;font-weight:900;color:var(--red)">Too Early!</div>`:''}
        ${extra}
      </div>
    </div>`;
  }
  window._reactionTap=()=>{
    if(phase==='idle'){
      betAmount=getBet();if(!betAmount)return;
      phase='waiting';render('waiting');
      const delay=1500+rng()*3000;
      timer=setTimeout(()=>{phase='go';startTime=Date.now();render('go');
        timer=setTimeout(()=>{if(phase==='go'){phase='idle';render('idle',`<div style="font-size:16px;color:var(--red);margin-top:10px">Missed! Too slow!</div>`);loseBet(betAmount,main);setResult('Too slow -$'+fmt(betAmount),'lose');addHistory('-$'+fmt(betAmount),'lose');startCooldown(600);}},1200);
      },delay);
    } else if(phase==='waiting'){
      clearTimeout(timer);phase='idle';
      loseBet(betAmount,main);setResult('Too early! -$'+fmt(betAmount),'lose');addHistory('-$'+fmt(betAmount),'lose');
      render('early');startCooldown(600);
    } else if(phase==='go'){
      clearTimeout(timer);
      const elapsed=Date.now()-startTime;
      let mult=1.0;
      for(let t of TIERS){if(elapsed<=t.ms){mult=t.mult;break;}}
      mult*=(1-0.04);
      phase='idle';
      render('result',`<div style="font-size:18px;font-weight:800;color:var(--neon)">${elapsed}ms</div><div style="font-size:14px;color:var(--text2);margin-top:6px">${mult.toFixed(2)}×</div>`);
      if(mult>1){winBet(betAmount*mult-betAmount,main);setResult(elapsed+'ms — '+mult.toFixed(1)+'× +$'+fmt(betAmount*mult-betAmount),'win');addHistory('+$'+fmt(betAmount*mult-betAmount),'win');}
      else{loseBet(betAmount*(1-mult),main);setResult(elapsed+'ms — Loss','lose');addHistory('-$'+fmt(betAmount*(1-mult)),'lose');}
      startCooldown(600);
    }
  };
  const sidebar=document.getElementById('gameSidebar');
  sidebar.innerHTML=`<div class="bet-panel">
    <div class="bet-panel-title">Reaction Test</div>
    <div class="bet-input-wrap"><input class="bet-input" id="betInput" type="number" value="10" min="1"><button class="btn-max" onclick="maxBet()">MAX</button></div>
    <div class="spacer-sm"></div>
    <div style="padding:10px;background:var(--bg3);border-radius:8px;font-size:12px;color:var(--text2);line-height:1.6;">
      Under 200ms = 3×<br>Under 300ms = 2×<br>Under 450ms = 1.5×<br>Under 600ms = 1.2×
    </div>
    <div class="cooldown-bar" style="margin-top:8px;"><div class="cooldown-fill" id="cooldownFill" style="width:0"></div></div>
  </div>
  <div class="result-panel" id="resultPanel"><div class="result-label">Result</div><div class="result-val" id="resultVal">—</div></div>
  <div class="history-panel"><div class="history-title">Recent</div><div class="history-list" id="historyList"></div></div>`;
  render('idle');
  return {destroy:()=>{if(timer)clearTimeout(timer);phase='idle';}};
};

// ===== MEMORY TILES =====
GAME_RUNNERS.memory = function() {
  const main=document.getElementById('gameMain');
  const COLS=[['#e00','#0a0','#00a','#a0a','#a80','#088','#e60','#484'],['#f44','#4f4','#44f','#f4f','#ff4','#4ff','#fa4','#4af']];
  let sequence=[],playerSeq=[],level=0,phase='watch',inGame=false,betAmount=0;
  function render(){
    const n=Math.min(4+level,8);
    main.innerHTML=`<div style="padding:20px;display:flex;flex-direction:column;align-items:center;gap:16px;width:100%;">
      <div style="font-size:13px;color:var(--text2);text-align:center;">${phase==='watch'?'Watch the sequence...':`Repeat the sequence (${playerSeq.length}/${sequence.length})`} — Level ${level+1}</div>
      <div class="memory-grid" style="grid-template-columns:repeat(4,1fr);width:min(280px,90%);">
        ${COLS[0].map((c,i)=>`<div class="memory-tile" id="mt${i}" style="background:${inGame?c+'33':'var(--bg3)'};border:2px solid ${inGame?c+'55':'var(--border)'};" onclick="window._memoryTap(${i})"></div>`).join('')}
      </div>
    </div>`;
  }
  function flash(idx,on){
    const el=document.getElementById('mt'+idx);
    if(!el)return;
    const c=COLS[0][idx];
    el.style.background=on?c:'var(--bg3)';
    el.style.border=`2px solid ${on?c+'aa':'var(--border)'}`;
    if(on)el.style.boxShadow=`0 0 14px ${c}`;
    else el.style.boxShadow='';
  }
  function playSequence(){
    phase='watch';render();
    let i=0;
    function step(){
      if(i>=sequence.length){phase='input';render();return;}
      setTimeout(()=>{flash(sequence[i],true);setTimeout(()=>{flash(sequence[i],false);i++;setTimeout(step,200);},500);},100);
    }
    step();
  }
  window._memoryTap=(idx)=>{
    if(phase!=='input'||!inGame)return;
    flash(idx,true);setTimeout(()=>flash(idx,false),200);
    playerSeq.push(idx);
    if(playerSeq[playerSeq.length-1]!==sequence[playerSeq.length-1]){
      inGame=false;
      loseBet(betAmount,main);setResult('Wrong! -$'+fmt(betAmount),'lose');addHistory('-$'+fmt(betAmount),'lose');
      phase='done';render();startCooldown(600);
      document.getElementById('playBtn').textContent='New Game';
      return;
    }
    if(playerSeq.length===sequence.length){
      level++;
      const m=1+(level*0.4)*0.96;
      if(level>=6){
        inGame=false;const p=betAmount*m;winBet(p-betAmount,main);setResult('Max Level! +$'+fmt(p-betAmount),'win');addHistory('+$'+fmt(p-betAmount),'win');
        startCooldown(500);document.getElementById('playBtn').textContent='New Game';return;
      }
      setResult('Level '+level+'! '+m.toFixed(1)+'×','win');
      // Cashout or continue
      document.getElementById('resultVal').innerHTML=`Level ${level}! — <button onclick="window._memoryCashout()" class="play-btn cashout" style="display:inline-block;padding:6px 14px;margin-left:8px;font-size:12px;">Cash $${fmt(betAmount*m)}</button>`;
      // Auto-continue after 2s
      playerSeq=[];sequence.push(Math.floor(rng()*8));
      setTimeout(()=>{if(inGame)playSequence();},2200);
    }
  };
  window._memoryCashout=()=>{
    if(!inGame)return;
    inGame=false;
    const m=(1+(level*0.4))*0.96;
    winBet(betAmount*m-betAmount,main);setResult('Cashed! +$'+fmt(betAmount*m-betAmount),'win');addHistory('+$'+fmt(betAmount*m-betAmount),'win');
    startCooldown(500);document.getElementById('playBtn').textContent='New Game';
  };
  makeBetPanel('gameSidebar',{label:'Start',onPlay:'window._memoryStart()'});
  window._memoryStart=()=>{
    betAmount=getBet();if(!betAmount)return;
    level=0;inGame=true;sequence=[Math.floor(rng()*8)];playerSeq=[];
    render();setTimeout(playSequence,600);
    document.getElementById('playBtn').textContent='New Game';
  };
  main.innerHTML=`<div style="text-align:center;color:var(--text3);font-size:15px;padding:20px;">Watch and repeat the sequence!</div>`;
  render();
  return {destroy:()=>{inGame=false;}};
};

// ===== CRASH X =====
GAME_RUNNERS.crash2 = function() {
  const main=document.getElementById('gameMain');
  main.innerHTML=`<canvas id="cxCanvas" width="440" height="280" style="display:block;margin:auto;border-radius:12px;background:rgba(5,5,20,0.8);border:1px solid var(--border);"></canvas>`;
  const canvas=document.getElementById('cxCanvas');
  const ctx=canvas.getContext('2d');
  let mult=1,crashed=false,running=false,cashedOut=false,betAmount=0,animId=null;
  let history=[];
  function drawHist(){
    const w=440,h=280;
    ctx.clearRect(0,0,w,h);
    // grid
    ctx.strokeStyle='rgba(255,255,255,0.04)';ctx.lineWidth=1;
    for(let i=0;i<=4;i++){const y=20+i*55;ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(w,y);ctx.stroke();}
    // history bars
    const bw=w/(Math.max(history.length,1));
    history.forEach((v,i)=>{
      const bh=Math.min((v/20)*220,220);
      ctx.fillStyle=v>=2?'rgba(0,200,80,0.3)':'rgba(255,61,90,0.3)';
      ctx.fillRect(i*bw,h-bh-20,bw-2,bh);
      ctx.fillStyle=v>=2?'#0f6':'#f55';
      ctx.font='9px sans-serif';ctx.textAlign='center';
      ctx.fillText(v.toFixed(1)+'×',i*bw+bw/2,h-bh-24);
    });
    // Current mult
    if(running||crashed){
      const color=crashed?'#f55':'#0cf';
      ctx.font=`bold ${crashed?36:52}px sans-serif`;ctx.textAlign='center';
      ctx.fillStyle=color;
      ctx.fillText(mult.toFixed(2)+'×',w/2,h/2+(crashed?10:0));
      if(crashed){ctx.font='bold 18px sans-serif';ctx.fillStyle='rgba(255,80,80,0.8)';ctx.fillText('CRASHED',w/2,h/2+36);}
    } else {
      ctx.font='bold 18px sans-serif';ctx.textAlign='center';ctx.fillStyle='rgba(255,255,255,0.2)';
      ctx.fillText('Place bet to fly',w/2,h/2);
    }
  }
  drawHist();
  const sidebar=document.getElementById('gameSidebar');
  makeBetPanel('gameSidebar',{label:'Launch',onPlay:'window._cx2Bet()'});
  const bp=sidebar.querySelector('.bet-panel');
  const co=document.createElement('button');
  co.className='play-btn cashout';co.id='cx2Co';co.style.display='none';co.textContent='Cash Out';
  co.onclick=()=>window._cx2Cash();bp.insertBefore(co,bp.querySelector('.cooldown-bar'));
  function genCrash(){
    const r=rng();
    if(r<0.05)return 1+(rng()*0.2);
    return Math.max(1.05,0.98/(rng()*(1-0.02)));
  }
  let crashAt=2,speed=0.003;
  window._cx2Bet=()=>{
    if(running)return;betAmount=getBet();if(!betAmount)return;
    running=true;crashed=false;cashedOut=false;mult=1;speed=0.003;
    crashAt=genCrash();
    document.getElementById('playBtn').disabled=true;
    document.getElementById('cx2Co').style.display='block';
    function tick(){
      if(!running)return;
      speed+=0.000018;mult+=speed*mult;
      drawHist();
      if(mult>=crashAt){
        running=false;crashed=true;
        history.push(mult);if(history.length>14)history.shift();
        drawHist();
        document.getElementById('cx2Co').style.display='none';
        document.getElementById('playBtn').disabled=false;
        if(!cashedOut){loseBet(betAmount,main);setResult('Crashed '+mult.toFixed(2)+'×','lose');addHistory('-$'+fmt(betAmount),'lose');}
        startCooldown(600);return;
      }
      animId=requestAnimationFrame(tick);
    }
    animId=requestAnimationFrame(tick);
  };
  window._cx2Cash=()=>{
    if(!running||crashed||cashedOut)return;
    cashedOut=true;running=false;
    if(animId)cancelAnimationFrame(animId);
    history.push(mult);if(history.length>14)history.shift();
    const p=betAmount*mult*0.97;
    winBet(p-betAmount,main);setResult('Cashed '+mult.toFixed(2)+'× +$'+fmt(p-betAmount),'win');addHistory('+$'+fmt(p-betAmount),'win');
    document.getElementById('cx2Co').style.display='none';
    document.getElementById('playBtn').disabled=false;
    startCooldown(500);drawHist();
  };
  return {destroy:()=>{running=false;if(animId)cancelAnimationFrame(animId);}};
};

// ===== NUMBER GUESS =====
GAME_RUNNERS.guess = function() {
  const main=document.getElementById('gameMain');
  let target=null, attempts=0, maxAttempts=7, betAmount=0, inGame=false;
  function render(hint=''){
    main.innerHTML=`<div style="display:flex;flex-direction:column;align-items:center;gap:20px;padding:30px;text-align:center;">
      <div style="font-size:14px;color:var(--text2)">Guess a number 1-100<br>You have ${maxAttempts-attempts} attempts left</div>
      <div style="display:flex;gap:12px;align-items:center;">
        <input class="guess-input" id="guessIn" type="number" min="1" max="100" placeholder="1-100" onkeydown="if(event.key==='Enter')window._guessGo()">
        <button class="play-btn" style="width:100px;padding:12px" onclick="window._guessGo()">Guess</button>
      </div>
      ${hint?`<div style="font-size:16px;font-weight:700;padding:10px 20px;border-radius:10px;background:var(--bg3)">${hint}</div>`:''}
      <div style="font-size:12px;color:var(--text3)">Fewer attempts = bigger payout</div>
    </div>`;
    document.getElementById('guessIn')?.focus();
  }
  window._guessGo=()=>{
    if(!inGame)return;
    const v=parseInt(document.getElementById('guessIn')?.value||0);
    if(!v||v<1||v>100){showToast('Enter 1-100','info');return;}
    attempts++;
    if(v===target){
      inGame=false;
      const mult=Math.max(1.2,(maxAttempts-attempts+1)*0.8);
      const p=betAmount*mult*(1-0.03);
      winBet(p-betAmount,main);setResult('Correct! +$'+fmt(p-betAmount),'win');addHistory('+$'+fmt(p-betAmount),'win');
      render(`🎉 Correct! It was ${target}! You won!`);startCooldown(600);
    } else if(attempts>=maxAttempts){
      inGame=false;
      loseBet(betAmount,main);setResult('Out of guesses -$'+fmt(betAmount),'lose');addHistory('-$'+fmt(betAmount),'lose');
      render(`❌ It was ${target}. Better luck next time!`);startCooldown(600);
    } else {
      const hint=v<target?`📈 Higher than ${v}! (${maxAttempts-attempts} left)`:
                          `📉 Lower than ${v}! (${maxAttempts-attempts} left)`;
      render(hint);
    }
  };
  makeBetPanel('gameSidebar',{label:'New Game',onPlay:'window._guessStart()'});
  window._guessStart=()=>{
    betAmount=getBet();if(!betAmount)return;
    target=Math.floor(rng()*100)+1;
    attempts=0;inGame=true;render();
    document.getElementById('playBtn').textContent='New Game';
  };
  main.innerHTML=`<div style="text-align:center;color:var(--text3);font-size:15px;padding:20px;">Guess the hidden number!</div>`;
  return {destroy:()=>{inGame=false;}};
};

// ===== BALLOON POP =====
GAME_RUNNERS.balloon = function() {
  const main=document.getElementById('gameMain');
  main.innerHTML=`<canvas id="balloonCanvas" width="420" height="380" style="display:block;margin:auto;cursor:pointer;" onclick="window._balloonPump()"></canvas>`;
  const canvas=document.getElementById('balloonCanvas');
  const ctx=canvas.getContext('2d');
  let size=30, maxSize=200, popped=false, inGame=false, betAmount=0;
  let crashAt=0;
  function draw(){
    ctx.clearRect(0,0,420,380);
    const cx=210,cy=200;
    const r=size;
    // balloon
    const hue=popped?0:200+Math.floor((size/maxSize)*60);
    ctx.beginPath();ctx.arc(cx,cy-r*0.3,r,0,Math.PI*2);
    ctx.fillStyle=popped?'rgba(255,50,50,0.3)':`hsla(${hue},90%,${60+size/maxSize*20}%,0.85)`;
    ctx.fill();
    ctx.strokeStyle=popped?'rgba(255,50,50,0.5)':`hsla(${hue},90%,80%,0.6)`;
    ctx.lineWidth=2;ctx.stroke();
    // string
    if(!popped){ctx.beginPath();ctx.moveTo(cx,cy+r*0.7);ctx.lineTo(cx,cy+r*0.7+50);ctx.strokeStyle='rgba(255,255,255,0.3)';ctx.lineWidth=1.5;ctx.stroke();}
    // text
    const mult=(size/30).toFixed(2);
    ctx.font=`bold ${popped?28:20}px sans-serif`;ctx.textAlign='center';
    ctx.fillStyle=popped?'#f55':'#fff';
    ctx.fillText(popped?'💥 POPPED!':`${mult}×`,cx,cy-r*0.3+(popped?10:5));
    if(!popped&&inGame){ctx.font='13px sans-serif';ctx.fillStyle='rgba(255,255,255,0.5)';ctx.fillText('Click to pump',cx,350);}
    if(!inGame&&!popped){ctx.font='14px sans-serif';ctx.fillStyle='rgba(255,255,255,0.4)';ctx.fillText('Place bet to start',cx,350);}
  }
  draw();
  window._balloonPump=()=>{
    if(!inGame)return;
    size+=8;
    if(size>=crashAt){
      popped=true;inGame=false;draw();
      loseBet(betAmount,main);setResult('Popped! -$'+fmt(betAmount),'lose');addHistory('-$'+fmt(betAmount),'lose');
      startCooldown(600);document.getElementById('cashoutBalloon').style.display='none';
    } else draw();
  };
  const sidebar=document.getElementById('gameSidebar');
  makeBetPanel('gameSidebar',{label:'Inflate!',onPlay:'window._balloonStart()'});
  const bp=sidebar.querySelector('.bet-panel');
  const co=document.createElement('button');
  co.id='cashoutBalloon';co.className='play-btn cashout';co.style.cssText='margin-top:8px;display:none;';
  co.textContent='Cash Out';co.onclick=()=>window._balloonCash();
  bp.insertBefore(co,bp.querySelector('.cooldown-bar'));
  window._balloonCash=()=>{
    if(!inGame)return;inGame=false;
    const m=size/30;const p=betAmount*m*0.96;
    winBet(p-betAmount,main);setResult((m).toFixed(2)+'× +$'+fmt(p-betAmount),'win');addHistory('+$'+fmt(p-betAmount),'win');
    draw();startCooldown(500);document.getElementById('cashoutBalloon').style.display='none';
  };
  window._balloonStart=()=>{
    betAmount=getBet();if(!betAmount)return;
    size=30;popped=false;inGame=true;
    crashAt=60+rng()*160;// random pop point
    draw();document.getElementById('cashoutBalloon').style.display='block';
    document.getElementById('playBtn').textContent='Restart';
  };
  return {destroy:()=>{inGame=false;}};
};

// ========== INIT ==========
window.addEventListener('DOMContentLoaded',()=>{
  loadState();
  buildGameCards();
  updateNav();
  // Remove loading screen
  setTimeout(()=>{
    const ls=document.getElementById('loadingScreen');
    ls.style.opacity='0';
    setTimeout(()=>ls.remove(),500);
  },1400);
  // Keyboard shortcuts
  document.addEventListener('keydown',e=>{
    if(e.key==='Escape'&&STATE.currentGame)showHome();
  });
});
// expose globals needed
window.showHome=showHome;
window.openDeposit=openDeposit;
window.closeDeposit=closeDeposit;
window.confirmDeposit=confirmDeposit;
window.setDepositQuick=setDepositQuick;
window.getBet=getBet;
window.setBet=setBet;
window.adjustBet=adjustBet;
window.maxBet=maxBet;
window.setResult=setResult;
window.addHistory=addHistory;
window.startCooldown=startCooldown;
window.fmt=fmt;
window.winBet=winBet;
window.loseBet=loseBet;
</script>
</body>
