// ===== TOWER CLIMB =====
GAME_RUNNERS.tower = function() {
  const ROWS=8, COLS=3;
  let grid=[], cleared=[], currentRow=ROWS-1, inGame=false, betAmount=0;
  const main=document.getElementById('gameMain');
  function buildGrid(){
    grid=[];
    for(let r=0;r<ROWS;r++){
      const bombIdx=Math.floor(rng()*COLS);
      grid.push(Array.from({length:COLS},(_,c)=>c===bombIdx?'bomb':'safe'));
    }
  }
  function render(){
    main.innerHTML=`<div style="padding:14px;width:100%;overflow-y:auto;max-height:460px;">
      ${Array.from({length:ROWS},(_,r)=>{
        const row=grid[r],rCleared=cleared.includes(r);
        const isActive=inGame&&r===currentRow;
        return `<div style="margin:4px 0;" class="tower-row">
          ${row.map((cell,c)=>{
            if(rCleared)return`<div class="tower-cell cleared" style="width:70px;height:40px;">${cell==='bomb'?'💣':'✓'}</div>`;
            if(!isActive)return`<div class="tower-cell" style="width:70px;height:40px;opacity:${inGame&&r>currentRow?0.4:0.8}">?</div>`;
