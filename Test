        </div>
        ${!reveal?`<div class="scratch-layer" id="scratchLayer" onclick="window._scratchReveal()">
          <div style="text-align:center"><div style="font-size:20px">🪙</div><div style="margin-top:4px">SCRATCH HERE</div></div>
        </div>`:''}
      </div>
      ${reveal&&p?`<div style="font-size:18px;font-weight:800;color:${p.mult>1?'var(--gold)':'var(--red)'}">${p.mult>1?'You won!':'Better luck next time'}</div>`:''}
    </div>`;
