function getBet() {
  const v = parseFloat(document.getElementById('betInput')?.value || 0);
  if (isNaN(v) || v <= 0) { showToast('Enter a valid bet', 'info'); return 0; }
  if (v > STATE.balance) { showToast('Insufficient balance', 'info'); return 0; }
  return v;
}

function setBet(v) {
  const inp = document.getElementById('betInput');
  if (inp) inp.value = Math.min(v, STATE.balance);
}
function adjustBet(mult) {
  const inp = document.getElementById('betInput');
  if (inp) inp.value = Math.max(0.01, Math.min(parseFloat(inp.value || 0) * mult, STATE.balance)).toFixed(2);
}
function maxBet() {
  const inp = document.getElementById('betInput');
  if (inp) inp.value = Math.min(STATE.balance * 0.25, STATE.balance).toFixed(2);
}

let cooldownActive = false;
function startCooldown(ms = 800) {
  cooldownActive = true;
  const btn = document.getElementById('playBtn');
  if (btn) btn.disabled = true;
  const fill = document.getElementById('cooldownFill');
  if (fill) {
    fill.style.width = '0%';
    fill.style.transition = `width ${ms}ms linear`;
    setTimeout(() => fill.style.width = '100%', 10);
  }
  setTimeout(() => {
    cooldownActive = false;
    if (btn) btn.disabled = false;
    if (fill) { fill.style.transition = 'none'; fill.style.width = '0'; }
  }, ms);
}

function setResult(txt, type) {
  const el = document.getElementById('resultVal');
  if (el) { el.textContent = txt; el.className = 'result-val ' + (type || ''); }
}

let historyItems = [];
function addHistory(txt, type) {
  historyItems.unshift({ txt, type });
  if (historyItems.length > 15) historyItems.pop();
  const el = document.getElementById('historyList');
  if (el) {
    el.innerHTML = historyItems.map(h => `<div class="history-item ${h.type}">${h.txt}</div>`).join('');
  }
}

// ========== HOUSE EDGE HELPERS ==========
function rng() { return Math.random(); }
// Biased random (house edge built-in)
function houseRng(houseEdge = 0.03) {
  return rng() * (1 - houseEdge);
}
// Streak detector (reduce wins after streaks)
const streakTracker = {};
function trackStreak(gameId, won) {
  if (!streakTracker[gameId]) streakTracker[gameId] = 0;
  streakTracker[gameId] = won ? streakTracker[gameId] + 1 : 0;
  return streakTracker[gameId];
}
function getStreakPenalty(gameId) {
  const s = streakTracker[gameId] || 0;
  if (s >= 5) return 0.25;
  if (s >= 3) return 0.12;
  return 0;
}

