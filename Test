          }).join('')}
        </div>`;
      }).reverse().join('')}
    </div>`;
  }
  window._towerClick=(r,c)=>{
    if(!inGame||r!==currentRow)return;
    const cell=grid[r][c];
    cleared.push(r);
    if(cell==='bomb'){
      inGame=false;
      loseBet(betAmount,main);setResult('Hit a bomb! -$'+fmt(betAmount),'lose');addHistory('-$'+fmt(betAmount),'lose');
      render();startCooldown(800);
      document.getElementById('playBtn').textContent='New Game';
      document.getElementById('cashoutTower').style.display='none';
    } else {
      currentRow--;
      const m=1+((ROWS-currentRow-1)*0.3);
      render();
      document.getElementById('cashoutTower').textContent=`Cash Out ${m.toFixed(1)}× $${fmt(betAmount*m*0.96)}`;
      if(currentRow<0){
        inGame=false;
        const p=betAmount*(1+ROWS*0.3)*0.96;
        winBet(p-betAmount,main);setResult('Top! +$'+fmt(p-betAmount),'win');addHistory('+$'+fmt(p-betAmount),'win');
        startCooldown(600);document.getElementById('cashoutTower').style.display='none';
      }
    }
  };
  const sidebar=document.getElementById('gameSidebar');
  makeBetPanel('gameSidebar',{label:'Build Tower',onPlay:'window._towerStart()'});
  const bp=sidebar.querySelector('.bet-panel');
  const coBtn=document.createElement('button');
  coBtn.id='cashoutTower';coBtn.className='play-btn cashout';coBtn.style.cssText='margin-top:8px;display:none;';
  coBtn.textContent='Cash Out';coBtn.onclick=()=>window._towerCashout();
  bp.insertBefore(coBtn,bp.querySelector('.cooldown-bar'));
  window._towerCashout=()=>{
    if(!inGame||cleared.length===0)return;
    inGame=false;
    const m=1+(cleared.length*0.3);
    const p=betAmount*m*0.96;
    winBet(p-betAmount,main);setResult('Cashed! +$'+fmt(p-betAmount),'win');addHistory('+$'+fmt(p-betAmount),'win');
    render();startCooldown(500);
    document.getElementById('cashoutTower').style.display='none';
  };
  window._towerStart=()=>{
    betAmount=getBet();if(!betAmount)return;
    buildGrid();cleared=[];currentRow=ROWS-1;inGame=true;
    render();document.getElementById('cashoutTower').style.display='block';
    document.getElementById('playBtn').textContent='New Game';
  };
  main.innerHTML=`<div style="text-align:center;color:var(--text3);font-size:15px;padding:20px;">Climb the tower — one safe per floor!</div>`;
  render();
  return {destroy:()=>{inGame=false;}};
};

